# Anthropic API key — required for the chat to work.
ANTHROPIC_API_KEY=

# Port the server listens on (optional, defaults to 3000).
PORT=3000

# Postgres connection string. Optional: without it the app runs in the original
# in-memory mode (no persistence, admin disabled). On Railway, reference the
# Postgres service's variable rather than hardcoding a URL:  ${{Postgres.DATABASE_URL}}
# Local dev (docker compose, see docker-compose.yml):
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/thesis

# Set to "disable" to force-disable SSL (e.g. some local setups). Remote DBs use SSL automatically.
# DATABASE_SSL=disable

# Shared secret gating the /admin dashboard and /api/admin/* routes.
# Without it, the admin surface is disabled (503). Use a long random string.
ADMIN_TOKEN=

# Python interpreter used to run the eval pipeline (default: python3).
PYTHON_BIN=python3
