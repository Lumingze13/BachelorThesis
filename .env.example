# --- Model provider (pick ONE; Build Plan §12: model = config, not code) ------
# Option A (study default): UvA AI Chat proxy — gpt-5.1, OpenAI-compatible, free
# for UvA students. Set BOTH of these and the participant chat uses the proxy.
# NOTE: the UvA proxy may be reachable only from the campus network — make one
# real call from the DEPLOYED server before fielding (Brief §6.2 reachability).
LLM_BASE_URL=https://llmproxy.uva.nl/v1
UVA_API_TOKEN=
# Override the model id if the proxy uses a different string (default: gpt-5.1).
MODEL_ID=gpt-5.1
# Optional: sampling temperature (default 0.9) and per-call timeout in ms.
# LLM_TEMPERATURE=0.9
# LLM_TIMEOUT_MS=90000

# Option B (fallback): Anthropic Claude. Used only if LLM_BASE_URL/UVA_API_TOKEN
# are NOT both set. The eval pipeline / silicon cohort always use Anthropic.
ANTHROPIC_API_KEY=

# Port the server listens on (optional, defaults to 3000).
PORT=3000

# Postgres connection string. Optional: without it the app runs in the original
# in-memory mode (no persistence, admin disabled). On Railway, reference the
# Postgres service's variable rather than hardcoding a URL:  ${{Postgres.DATABASE_URL}}
# Local dev (docker compose, see docker-compose.yml):
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/thesis

# Set to "disable" to force-disable SSL (e.g. some local setups). Remote DBs use SSL automatically.
# DATABASE_SSL=disable

# Shared secret gating the /admin dashboard and /api/admin/* routes.
# Without it, the admin surface is disabled (503). Use a long random string.
ADMIN_TOKEN=

# Read-only share link gating the /results page (anonymized supervisor view).
# Serves only de-identified, name-stripped data — no delete, no PII export, no
# run launching. If unset, /results falls back to ADMIN_TOKEN only. Use a long
# random string DISTINCT from ADMIN_TOKEN so you can share results safely.
RESULTS_TOKEN=

# Python interpreter used to run the eval pipeline (default: python3).
PYTHON_BIN=python3
